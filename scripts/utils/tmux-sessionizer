#!/usr/bin/env bash

# Parse flags
SKIP_HYDRATE=0
while [[ "$1" == --* ]]; do
    case "$1" in
        --simple)
            SKIP_HYDRATE=1
            shift
            ;;
        *)
            shift
            ;;
    esac
done

switch_to() {
    if [[ -z $TMUX ]]; then
        tmux attach-session -t $1
    else
        tmux switch-client -t $1
    fi
}

has_session() {
    tmux list-sessions | grep -q "^$1:"
}

hydrate() {
    local session=$1
    local dir=$2

    # Obsidian: just one window called notes
    if [[ "$dir" == *obsd* ]] || [[ "$dir" == *obsidian* ]]; then
        tmux rename-window -t "$session:1" "notes"
        tmux send-keys -t "$session:notes" "nvim +Neotree ." Enter
        return
    fi

    # Default layout for all other projects:
    #
    # Window 1: code
    # ┌─────────────┬─────────────┐
    # │   Neovim    │ Claude Code │
    # │   (60%)     │   (40%)     │
    # └─────────────┴─────────────┘
    #
    # Window 2: git
    # ┌───────────────────────────┐
    # │  lazygit                  │
    # └───────────────────────────┘
    #
    # Window 3: terminal
    # ┌───────────────────────────┐
    # │  clean shell              │
    # └───────────────────────────┘
    # Window 4: opencode
    # ┌───────────────────────────┐
    # │  clean opencode             │
    # └───────────────────────────┘
    
    # Window 1: claude (neovim + claude)
    tmux rename-window -t "$session:1" "claude"
    tmux set-option -t "$session:claude" automatic-rename off
    tmux send-keys -t "$session:claude" "nvim +Neotree ." Enter
    tmux split-window -h -t "$session:claude" -c "$dir" -l 40%
    tmux send-keys -t "$session:claude.1" "claude" Enter
    tmux select-pane -t "$session:claude.0"

    # Window 2: git
    tmux new-window -t "$session" -n "git" -c "$dir"
    tmux send-keys -t "$session:git" "lazygit" Enter

    # Window 3: terminal
    tmux new-window -t "$session" -n "terminal" -c "$dir"

    # Window 4: opencode (neovim + opencode)
    tmux new-window -t "$session" -n "opencode" -c "$dir"
    tmux send-keys -t "$session:opencode" "nvim +Neotree ." Enter
    tmux split-window -h -t "$session:opencode" -c "$dir" -l 40%
    tmux send-keys -t "$session:opencode.1" "opencode" Enter
    tmux select-pane -t "$session:opencode.0"

    # Focus back on claude window
    tmux select-window -t "$session:claude"
}

if [[ $SKIP_HYDRATE -eq 1 ]]; then
    # Simple mode: go straight to home directory
    selected="$HOME"
elif [[ $# -eq 1 ]]; then
    selected=$1
else
    # If someone wants to make this extensible, i'll accept
    # PR
    selected=$(find ~/ ~/Documents ~/Repos -mindepth 1 -maxdepth 1 -type d | fzf)
fi

if [[ -z $selected ]]; then
    exit 0
fi

selected_name=$(basename "$selected" | tr . _)
tmux_running=$(pgrep tmux)

if [[ -z $TMUX ]] && [[ -z $tmux_running ]]; then
    tmux new-session -ds $selected_name -c $selected
    if [[ $SKIP_HYDRATE -eq 0 ]]; then
        hydrate $selected_name $selected
    fi
    tmux attach-session -t $selected_name
    exit 0
fi

if ! has_session $selected_name; then
    tmux new-session -ds $selected_name -c $selected
    if [[ $SKIP_HYDRATE -eq 0 ]]; then
        hydrate $selected_name $selected
    fi
fi

switch_to $selected_name
