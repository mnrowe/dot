
#!/bin/sh

# 🐧🏡 Linux Homelab Init - Install Ansible
# Compatible with Ubuntu, Debian, RHEL, Fedora, CentOS, Rocky, Alma, Arch

set -e  # Exit on error
set -u  # Exit on undefined variable

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

log_info() {
    printf "${GREEN}[INFO]${NC} %s\n" "$1"
}

log_error() {
    printf "${RED}[ERROR]${NC} %s\n" "$1" >&2
}

log_warn() {
    printf "${YELLOW}[WARN]${NC} %s\n" "$1"
}

# Check if sudo is available for package installation
if [ "$(id -u)" -ne 0 ]; then
    if ! command -v sudo >/dev/null 2>&1; then
        log_error "This script requires sudo to install packages"
        exit 1
    fi
    SUDO="sudo"
else
    SUDO=""
fi

# Detect OS
detect_os() {
    if [ -f /etc/os-release ]; then
        . /etc/os-release
        OS=$ID
        OS_VERSION=$VERSION_ID
    else
        log_error "Cannot detect OS. /etc/os-release not found"
        exit 1
    fi
}

# Install Ansible based on OS
install_ansible() {
    case "$OS" in
        ubuntu|debian|pop)
            log_info "Detected $OS - Installing Ansible via PPA"
            $SUDO apt-get update -qq || { log_error "Failed to update package lists"; exit 1; }
            $SUDO apt-get install -y software-properties-common || { log_error "Failed to install software-properties-common"; exit 1; }
            $SUDO add-apt-repository --yes --update ppa:ansible/ansible || { log_error "Failed to add Ansible PPA"; exit 1; }
            $SUDO apt-get install -y ansible python3-argcomplete || { log_error "Failed to install Ansible"; exit 1; }
            $SUDO activate-global-python-argcomplete3 || log_warn "Failed to activate argcomplete"
            ;;
        rhel|centos|rocky|almalinux)
            log_info "Detected $OS - Installing Ansible via EPEL"
            if ! command -v ansible >/dev/null 2>&1; then
                $SUDO yum install -y epel-release || { log_error "Failed to install EPEL"; exit 1; }
                $SUDO yum install -y ansible python3-argcomplete || { log_error "Failed to install Ansible"; exit 1; }
            fi
            ;;
        fedora)
            log_info "Detected Fedora - Installing Ansible via DNF"
            $SUDO dnf install -y ansible python3-argcomplete || { log_error "Failed to install Ansible"; exit 1; }
            ;;
        arch|manjaro)
            log_info "Detected $OS - Installing Ansible via Pacman"
            $SUDO pacman -Sy --noconfirm ansible python-argcomplete || { log_error "Failed to install Ansible"; exit 1; }
            ;;
        opensuse*|sles)
            log_info "Detected $OS - Installing Ansible via Zypper"
            $SUDO zypper refresh || { log_error "Failed to refresh repositories"; exit 1; }
            $SUDO zypper install -y ansible python3-argcomplete || { log_error "Failed to install Ansible"; exit 1; }
            ;;
        *)
            log_error "Unsupported OS: $OS"
            log_info "Attempting to install via pip as fallback..."
            if command -v pip3 >/dev/null 2>&1; then
                pip3 install --upgrade ansible argcomplete || { log_error "Failed to install Ansible via pip"; exit 1; }
            else
                log_error "pip3 not found. Please install Ansible manually"
                exit 1
            fi
            ;;
    esac
}

# Verify installation
verify_ansible() {
    if command -v ansible >/dev/null 2>&1; then
        ANSIBLE_VERSION=$(ansible --version | head -n1)
        log_info "Ansible installed successfully: $ANSIBLE_VERSION"
        return 0
    else
        log_error "Ansible installation verification failed"
        return 1
    fi
}

# Main execution
main() {
    log_info "Starting Ansible installation..."
    detect_os
    log_info "Detected OS: $OS ${OS_VERSION:-unknown}"
    install_ansible
    verify_ansible || exit 1
    log_info "Installation complete!"
}

main "$@"
