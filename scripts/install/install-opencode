#!/usr/bin/env bash

install-opencode() {
	echo "Installing OpenCode AI - Open source AI coding assistant..."

	if [[ $OSTYPE =~ ^darwin ]]; then
		if type brew &>/dev/null; then
			brew tap opencode-ai/opencode
			brew install opencode
		else
			# Use official install script
			curl -fsSL https://opencode.ai/install | bash
		fi
		return
	fi

	if [[ $OSTYPE =~ ^msys ]]; then
		# Windows: use official install script
		curl -fsSL https://opencode.ai/install | bash
		return
	fi

	# Check for npm (cross-platform option)
	if type npm &>/dev/null; then
		echo "Installing via npm..."
		if npm install -g opencode 2>/dev/null; then
			return
		else
			echo "npm package not available, trying alternative method..."
		fi
	fi

	# Arch Linux with paru
	if type paru &>/dev/null; then
		if paru -S --noconfirm opencode 2>/dev/null; then
			return
		else
			echo "paru package not available, trying alternative method..."
		fi
	fi

	# Arch Linux with yay
	if type yay &>/dev/null; then
		if yay -S --noconfirm opencode 2>/dev/null; then
			return
		else
			echo "yay package not available, trying alternative method..."
		fi
	fi

	# Fallback: use official install script
	if type curl &>/dev/null; then
		echo "Installing via official install script..."
		curl -fsSL https://opencode.ai/install | bash
		return
	fi

	echo "OS unsupported by this installer: $OSTYPE"
	echo "Please visit https://opencode.ai/download for manual installation"
	return 1
}

install-opencode
