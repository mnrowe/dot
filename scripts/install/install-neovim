#!/usr/bin/env bash

install-neovim() {
	echo "Installing Neovim..."

	# Check if already installed
	if type nvim &>/dev/null; then
		echo "Neovim is already installed: $(nvim --version | head -1)"
		return 0
	fi

	if [[ $OSTYPE =~ ^darwin ]]; then
		if type brew &>/dev/null; then
			echo "Installing via Homebrew..."
			brew install neovim
			return 0
		fi
	fi

	if [[ $OSTYPE =~ ^msys ]]; then
		if type winget &>/dev/null; then
			echo "Installing via winget..."
			winget install --id neovim.neovim
			return 0
		fi
	fi

	# For Linux, prefer downloading latest release over package managers
	# (apt/dnf often have very old versions)
	if [[ $OSTYPE =~ ^linux ]] || type curl &>/dev/null; then
		echo "Installing latest stable release from GitHub..."
		local arch
		case "$(uname -m)" in
			x86_64)  arch="x86_64" ;;
			aarch64) arch="arm64" ;;
			*) echo "Unsupported architecture: $(uname -m)"; return 1 ;;
		esac

		local tarball="nvim-linux-${arch}.tar.gz"
		cd /tmp || return 1

		if curl -fLO "https://github.com/neovim/neovim/releases/latest/download/${tarball}"; then
			sudo rm -rf /opt/nvim-linux-x86_64 /opt/nvim-linux-arm64 /opt/nvim-linux64
			sudo tar -C /opt -xzf "$tarball"
			rm -f "$tarball"

			# Add to PATH if not already there
			if ! grep -q "/opt/nvim-linux" "$HOME/.bashrc" 2>/dev/null; then
				echo 'export PATH="/opt/nvim-linux-x86_64/bin:$PATH"' >> "$HOME/.bashrc"
				echo "Added Neovim to PATH in ~/.bashrc"
			fi

			echo "Neovim installed successfully!"
			echo "Run 'source ~/.bashrc' or restart your shell to use nvim"
			return 0
		else
			echo "Failed to download latest release, trying package manager..."
		fi
	fi

	# Fallback to package managers
	if type dnf &>/dev/null; then
		echo "Installing via dnf..."
		if sudo dnf install -y neovim; then
			return 0
		fi
	fi

	if type apt-get &>/dev/null; then
		echo "Installing via apt..."
		sudo apt-get update
		if sudo apt-get install -y neovim; then
			echo "Warning: apt version may be outdated. Consider using a newer version."
			return 0
		fi
	fi

	echo "Failed to install Neovim"
	return 1
}

install-neovim
