#!/usr/bin/env bash

install-tmux() {
	local install_cmd

	# macOS
	if [[ "$OSTYPE" == darwin* ]]; then
		command -v brew &>/dev/null && brew install tmux && return
		echo "Homebrew not found. Please install Homebrew first." >&2
		return 1
	fi

	# Windows (Git Bash/MSYS2)
	if [[ "$OSTYPE" == msys* ]] || [[ "$OSTYPE" == cygwin* ]] || [[ "$OSTYPE" == win32 ]]; then
		echo "tmux is not available for Windows (MSYS2/Git Bash)" >&2
		return 1
	fi

	# Linux distributions
	if command -v apt-get &>/dev/null; then
		sudo apt-get update && sudo apt-get install -y tmux && return
	elif command -v dnf &>/dev/null; then
		sudo dnf install -y tmux && return
	elif command -v yum &>/dev/null; then
		sudo yum install -y tmux && return
	elif command -v pacman &>/dev/null; then
		sudo pacman -S --noconfirm tmux && return
	elif command -v zypper &>/dev/null; then
		sudo zypper install -y tmux && return
	fi

	echo "Error: Unsupported OS or package manager not found: $OSTYPE" >&2
	return 1
}

install-tmux
