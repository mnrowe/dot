#!/usr/bin/env bash
# opencode-model - Switch between AI models and launch opencode
# Can be deployed across machines via dotfiles repo

set -e

# Colors for output
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Model definitions
declare -A MODELS=(
    ["claude"]="anthropic/claude-opus-4-6"
    ["claude-opus"]="anthropic/claude-opus-4-6"
    ["claude-sonnet"]="anthropic/claude-sonnet-4-5"
    ["sonnet"]="anthropic/claude-sonnet-4-5"
    ["gpt4"]="openai/gpt-4-turbo"
    ["gpt4o"]="openai/gpt-4o"
    ["gpt4-turbo"]="openai/gpt-4-turbo"
    ["gemini"]="google/gemini-pro"
    ["gemini-pro"]="google/gemini-pro"
)

usage() {
    cat <<EOF
Usage: opencode-model [MODEL] [DIRECTORY]

Switch between AI models and optionally launch opencode.

Models:
  claude, claude-opus    Claude Opus 4.6 (most capable)
  claude-sonnet, sonnet  Claude Sonnet 4.5 (balanced)
  gpt4, gpt4-turbo       GPT-4 Turbo
  gpt4o                  GPT-4o
  gemini, gemini-pro     Gemini Pro

Commands:
  list                   List all available models
  current                Show currently configured model
  <model>                Switch to model and launch opencode in current dir
  <model> <dir>          Switch to model and launch opencode in specified dir

Examples:
  opencode-model claude              # Launch opencode with Claude Opus
  opencode-model sonnet ~/project    # Launch opencode with Sonnet in ~/project
  opencode-model list                # List available models
  opencode-model current             # Show current model

Environment:
  Requires ~/.env with OPENROUTER_API_KEY set
  Automatically configures ANTHROPIC_API_KEY and ANTHROPIC_BASE_URL
EOF
}

list_models() {
    echo -e "${BLUE}Available models:${NC}"
    echo ""
    echo "  claude, claude-opus    → anthropic/claude-opus-4-6"
    echo "  claude-sonnet, sonnet  → anthropic/claude-sonnet-4-5"
    echo "  gpt4, gpt4-turbo       → openai/gpt-4-turbo"
    echo "  gpt4o                  → openai/gpt-4o"
    echo "  gemini, gemini-pro     → google/gemini-pro"
    echo ""
}

show_current() {
    if [[ -n "$ANTHROPIC_MODEL" ]]; then
        echo -e "${GREEN}Current model:${NC} $ANTHROPIC_MODEL"
    else
        echo -e "${YELLOW}No model currently set${NC}"
        echo "Set a default in ~/.env or use: opencode-model <model>"
    fi
}

set_model() {
    local model_key="$1"
    local model_id="${MODELS[$model_key]}"

    if [[ -z "$model_id" ]]; then
        echo -e "${YELLOW}Unknown model: $model_key${NC}"
        echo ""
        list_models
        exit 1
    fi

    export ANTHROPIC_MODEL="$model_id"
    echo -e "${GREEN}✓${NC} Switched to: $model_id"
}

launch_opencode() {
    local dir="${1:-.}"

    # Check if opencode is available
    if ! command -v opencode &>/dev/null; then
        echo -e "${YELLOW}Warning: opencode command not found${NC}"
        echo "Install it with: npm install -g opencode"
        exit 1
    fi

    # Check if API key is configured
    if [[ -z "$ANTHROPIC_API_KEY" && -z "$OPENROUTER_API_KEY" ]]; then
        echo -e "${YELLOW}Warning: No API key found${NC}"
        echo "Add OPENROUTER_API_KEY to ~/.env"
        exit 1
    fi

    # Ensure base URL is set for OpenRouter
    export ANTHROPIC_BASE_URL="${ANTHROPIC_BASE_URL:-https://openrouter.ai/api/v1}"

    echo -e "${BLUE}Launching opencode in:${NC} $dir"
    echo -e "${BLUE}Using model:${NC} $ANTHROPIC_MODEL"
    echo ""

    cd "$dir" && opencode
}

# Main logic
case "${1:-}" in
    -h|--help|help)
        usage
        ;;
    list|ls)
        list_models
        ;;
    current|show)
        show_current
        ;;
    "")
        usage
        exit 1
        ;;
    *)
        set_model "$1"
        shift
        launch_opencode "$@"
        ;;
esac
