#!/bin/sh
#
# 🚀 Dotfiles Bootstrap Script
# Run this on a fresh box to set everything up
#
# Usage:
#   ./bootstrap              # Interactive mode
#   ./bootstrap --minimal    # Minimal install (essentials only: tmux, nvim, bash)
#   ./bootstrap --server     # Server profile (development tools, no GUI apps)
#   ./bootstrap --desktop    # Desktop profile (everything including GUI tools)
#

# Get script directory
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
export DOTFILES="$SCRIPT_DIR"

# Source common functions
# shellcheck source=scripts/lib/common.sh
. "$SCRIPT_DIR/scripts/lib/common.sh"

# Banner
show_banner() {
    cat << 'EOF'
    ____        __  _____ __
   / __ \____  / /_/ __(_) /__  _____
  / / / / __ \/ __/ /_/ / / _ \/ ___/
 / /_/ / /_/ / /_/ __/ / /  __(__  )
/_____/\____/\__/_/ /_/_/\___/____/

 Bootstrap Script - Set up a fresh box
EOF
    echo ""
}

# Installation profiles
profile_minimal() {
    log_info "Installing MINIMAL profile (essentials only)..."
    install_essentials
    configure_essentials
}

profile_server() {
    log_info "Installing SERVER profile (no GUI)..."
    install_essentials
    install_dev_tools
    install_cli_tools
    configure_all
}

profile_desktop() {
    log_info "Installing DESKTOP profile (everything)..."
    install_essentials
    install_dev_tools
    install_cli_tools
    install_gui_tools
    install_optional
    configure_all
}

# Core installations
install_essentials() {
    log_step "Installing essential tools..."

    # Run install scripts
    run_if_exists "$SCRIPT_DIR/scripts/install/install-tmux"
    run_if_exists "$SCRIPT_DIR/scripts/install/install-neovim"
}

install_dev_tools() {
    log_step "Installing development tools..."

    # Node.js via nvm (installs nvm first if needed, then node + npm)
    run_if_exists "$SCRIPT_DIR/scripts/install/install-nvm"
    run_if_exists "$SCRIPT_DIR/scripts/install/install-nodejs"

    # Other programming languages and build tools
    run_if_exists "$SCRIPT_DIR/scripts/install/install-golang"
    run_if_exists "$SCRIPT_DIR/scripts/install/install-ansible"
}

install_cli_tools() {
    log_step "Installing CLI tools..."

    # Git and terminal tools
    run_if_exists "$SCRIPT_DIR/scripts/install/install-lazygit"

	# AI/Editor tools
	run_if_exists "$SCRIPT_DIR/scripts/install/install-opencode"
	run_if_exists "$SCRIPT_DIR/scripts/install/install-claude"
	run_if_exists "$SCRIPT_DIR/scripts/install/install-codex"
}

install_gui_tools() {
    log_step "Installing GUI tools..."

    # Terminal emulator and fonts
    run_if_exists "$SCRIPT_DIR/scripts/install/install-wezterm"
    run_if_exists "$SCRIPT_DIR/scripts/install/install-ubuntumono"
}

install_optional() {
    log_step "Installing optional tools..."

    run_if_exists "$SCRIPT_DIR/scripts/install/install-podman"
}

# Configuration
configure_essentials() {
    log_step "Configuring essential tools..."

    run_if_exists "$SCRIPT_DIR/scripts/config/config-bash"
    run_if_exists "$SCRIPT_DIR/scripts/config/config-tmux"
    run_if_exists "$SCRIPT_DIR/scripts/config/config-nvim"
    run_if_exists "$SCRIPT_DIR/scripts/config/config-scripts"
}

configure_all() {
    log_step "Configuring all tools..."

    # Run all config scripts
    for script in "$SCRIPT_DIR"/scripts/config/*; do
        if [ -x "$script" ]; then
            run_script "$script"
        fi
    done
}

# Helper functions
run_if_exists() {
    local script="$1"
    if [ -f "$script" ] && [ -x "$script" ]; then
        run_script "$script"
    else
        log_warn "Script not found or not executable: $script"
    fi
}

run_script() {
    local script="$1"
    local name
    name="$(basename "$script")"

    log_info "Running: $name"
    if "$script"; then
        log_success "Completed: $name"
        return 0
    else
        log_error "Failed: $name"
        # Continue with other scripts instead of failing entirely
        return 1
    fi
}

# Interactive mode
interactive_mode() {
    show_banner
    log_info "Select installation profile:"
    echo ""
    echo "  1) Minimal    - Essentials: tmux, neovim"
    echo "  2) Server     - Minimal + dev tools (nodejs, golang, ansible, lazygit, AI tools)"
    echo "  3) Desktop    - Server + GUI tools (wezterm, fonts, podman)"
    echo "  4) Custom     - Choose what to install"
    echo ""
    printf "Enter choice [1-4]: "
    read -r choice

    case "$choice" in
        1) profile_minimal ;;
        2) profile_server ;;
        3) profile_desktop ;;
        4) custom_install ;;
        *)
            log_error "Invalid choice"
            exit 1
            ;;
    esac
}

custom_install() {
    log_info "Custom installation mode"
    echo ""
    echo "Available install scripts:"
    echo ""

    local i=1
    local script_list=""
    for script in "$SCRIPT_DIR"/scripts/install/*; do
        if [ -x "$script" ]; then
            name="$(basename "$script")"
            echo "  $i) $name"
            # Use newline as separator to avoid index issues
            script_list="${script_list}${script}
"
            i=$((i + 1))
        fi
    done

    echo ""
    printf "Enter numbers to install (space-separated, e.g. '1 2 4'): "
    read -r selections

    for num in $selections; do
        # Extract the nth line from script_list
        script=$(echo "$script_list" | sed -n "${num}p")
        if [ -n "$script" ] && [ -f "$script" ]; then
            run_script "$script"
        else
            log_warn "Invalid selection: $num"
        fi
    done

    log_step "Running configuration scripts..."
    configure_all
}

# Main execution
main() {
    # Parse arguments
    case "${1:-}" in
        --minimal|minimal)
            show_banner
            profile_minimal
            ;;
        --server|server)
            show_banner
            profile_server
            ;;
        --desktop|desktop)
            show_banner
            profile_desktop
            ;;
        --help|-h)
            show_banner
            echo "Usage: $0 [OPTION]"
            echo ""
            echo "Options:"
            echo "  --minimal     Install essential tools only (tmux, nvim)"
            echo "  --server      Server profile (minimal + dev tools, CLI only, no GUI)"
            echo "  --desktop     Desktop profile (server + GUI tools: wezterm, fonts)"
            echo "  --help        Show this help"
            echo ""
            echo "No option: Interactive mode"
            exit 0
            ;;
        "")
            interactive_mode
            ;;
        *)
            log_error "Unknown option: $1"
            echo "Run '$0 --help' for usage"
            exit 1
            ;;
    esac

    echo ""
    log_success "Bootstrap complete! 🎉"
    log_info "You may need to restart your shell for changes to take effect"
}

main "$@"
